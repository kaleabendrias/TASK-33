            <directory>app/Application</directory>
            <directory>app/Infrastructure/Export</directory>
            <directory>app/Infrastructure/Repositories</directory>
        </include>
    </source>

    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:k8Yh3ARZSN0mLpGqMgWsnFdl+VqTGHMdKNGRPMPUMKo="/>
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="postgres"/>
        <env name="DB_PORT" value="5432"/>
        <env name="DB_DATABASE" value="service_platform_test"/>
        <env name="DB_USERNAME" value="app_user"/>
        <env name="DB_PASSWORD" value="app_secret_pass"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="SESSION_DRIVER" value="array"/>
